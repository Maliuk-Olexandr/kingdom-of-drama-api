<html>
  <head>
    <style>
      .container {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding: 30px;
        text-align: center;
        background-color: #f9f9f9;
      }
      .content {
        background-color: #ffffff;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
        display: inline-block;
        max-width: 500px;
      }
      .button {
        background-color: #a91e6a;
        color: #ffffff !important;
        padding: 14px 28px;
        text-decoration: none;
        border-radius: 8px;
        display: inline-block;
        font-weight: bold;
        margin: 25px 0;
      }
      .name {
        color: #a91e6a;
        font-weight: bold;
        text-transform: capitalize;
      }
      .warning {
        font-size: 13px;
        color: #666;
        font-style: italic;
      }
      .footer {
        margin-top: 20px;
        font-size: 12px;
        color: #888;
      }
    </style>
  </head>
  <body>
    <div class='container'>
      <div class='content'>
        <h2 style='color: #333;'>Dear
          <span class='name'>{{displayName}}</span>!</h2>
        <p style='color: #666;'>You have changed your email address on Kingdom of
          Drama to {{newEmail}}.</p>
        <p class='warning'>If this wasn't you, please change your password immediately and contact support.</p>
      </div>
      <div class='footer'>
        &copy; 2026 Kingdom of Drama. This email was sent automatically, please do not reply.
      </div>
    </div>
  </body>
</html>
